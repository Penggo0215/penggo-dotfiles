font-family = "JetBrainsMono Nerd Font"
font-family = "PingFang SC"
font-size = 15.8
font-thicken = true
adjust-cell-height = 3

# Gruvbox Dark Theme
config-file = auto/gruvbox-dark.ghostty

# background-image = "/Users/penggo/Documents/penggo/图片/E42260A6-C452-42BB-BF03-1A29424FA823_1_105_c.jpeg"
# background-image-fit = cover
# background-image-position = center
# background-image-opacity = 0.05
# background-opacity = 0.92
# background-blur = 20 

# macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
window-padding-x = 10
window-padding-y = 10
window-save-state = always
window-colorspace = display-p3
window-padding-balance = true

cursor-style-blink = true
cursor-opacity = 0.8
adjust-cursor-thickness = 2
mouse-scroll-multiplier = 2

custom-shader = shaders/in-game-crt-cursor.glsl
custom-shader-animation = always

mouse-hide-while-typing = true

quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.15

confirm-close-surface = true

auto-update = check

shell-integration-features = cursor,sudo,no-title,ssh-env,ssh-terminfo,path

keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = shift+enter=text:\n
keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = cmd+l=new_split:left
keybind = cmd+b=new_split:down
keybind = cmd+shift+f=toggle_split_zoom

quit-after-last-window-closed = true
notify-on-command-finish = always

scrollback-limit = 25000000

macos-icon = custom
macos-custom-icon = /Users/penggo/dotfiles/ghostty/gruvbox-hard.icns
